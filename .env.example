# Serendipity Maximizer Environment
# Copy to .env and fill in

# LLM / LangChain
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...
# Or local / defense endpoints
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# LangGraph / Checkpointing
LANGGRAPH_CHECKPOINTER=sqlite  # or memory, postgres
CHECKPOINT_DB_PATH=.langgraph/checkpoints.db

# Serendipity / SADIP specific (Low-SWaP, assurance)
SADIP_ENV=dev
LOW_SWAP_MODE=true
AUDIT_LOG_LEVEL=INFO
RECOMBINATION_BUDGET=50

# Optional: external tools
TAVILY_API_KEY=
SERPER_API_KEY=
